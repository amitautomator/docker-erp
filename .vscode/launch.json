{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Program",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/node_modules/@microsoft/teamsfx-cli/bin/teamsfx",
      "args": ["dev"]
    },
    {
      "name": "SWA: Run docker-erp",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:3000",
      "preLaunchTask": "swa: start docker-erp",
      "webRoot": "${workspaceFolder}/",
      "timeout": 30000
    }
  ]
}
